{
  "info": {
    "name": "Bedomain API",
    "description": "Functional tests for Bedomain microservice",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "entityTypeId",
      "value": "",
      "type": "string"
    },
    {
      "key": "propertyId",
      "value": "",
      "type": "string"
    },
    {
      "key": "entityInstanceId",
      "value": "",
      "type": "string"
    },
    {
      "key": "jwtToken",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwtToken}}"
      }
    ]
  },
  "item": [
    {
      "name": "01 - Entity Types",
      "item": [
        {
          "name": "Create Entity Type",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201 Created', function() {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Response has id', function() {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('id');",
                  "    pm.collectionVariables.set('entityTypeId', jsonData.id);",
                  "});",
                  "pm.test('Response has correct name', function() {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.name).to.eql('Product');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/entity-types",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Product\",\n    \"description\": \"E-commerce product entity\"\n}"
            }
          }
        },
        {
          "name": "Get All Entity Types",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 OK', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response is paginated', function() {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('content');",
                  "    pm.expect(jsonData).to.have.property('totalElements');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/entity-types?page=0&size=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "entity-types"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Get Entity Type by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 OK', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response has correct id', function() {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.id).to.eql pm.collectionVariables.get('entityTypeId');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/entity-types/{{entityTypeId}}"
          }
        },
        {
          "name": "Update Entity Type",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 OK', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Name is updated', function() {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.name).to.eql('Updated Product');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/v1/entity-types/{{entityTypeId}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Updated Product\",\n    \"description\": \"Updated description\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "02 - Properties",
      "item": [
        {
          "name": "Create Property",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201 Created', function() {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Response has property id', function() {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('id');",
                  "    pm.collectionVariables.set('propertyId', jsonData.id);",
                  "});",
                  "pm.test('Property has correct dataType', function() {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.dataType).to.eql('NUMBER');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/entity-types/{{entityTypeId}}/properties",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"price\",\n    \"description\": \"Product price\",\n    \"dataType\": \"NUMBER\"\n}"
            }
          }
        },
        {
          "name": "Get Properties by Entity Type",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 OK', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response is an array', function() {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/entity-types/{{entityTypeId}}/properties"
          }
        },
        {
          "name": "Update Property",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 OK', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Description is updated', function() {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.description).to.eql('Updated price description');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/v1/entity-types/{{entityTypeId}}/properties/{{propertyId}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"price\",\n    \"description\": \"Updated price description\",\n    \"dataType\": \"NUMBER\"\n}"
            }
          }
        },
        {
          "name": "Delete Property",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 204 No Content', function() {",
                  "    pm.response.to.have.status(204);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/entity-types/{{entityTypeId}}/properties/{{propertyId}}"
          }
        }
      ]
    },
    {
      "name": "03 - Entity Instances",
      "item": [
        {
          "name": "Create Entity Instance",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201 Created', function() {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Response has instance id', function() {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('id');",
                  "    pm.collectionVariables.set('entityInstanceId', jsonData.id);",
                  "});",
                  "pm.test('Attributes are stored', function() {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.attributes).to.have.property('name');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/entities",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"entityTypeId\": \"{{entityTypeId}}\",\n    \"attributes\": {\n        \"name\": \"iPhone 15 Pro\",\n        \"price\": 999.99,\n        \"inStock\": true\n    }\n}"
            }
          }
        },
        {
          "name": "Get All Entity Instances",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 OK', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response is paginated', function() {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('content');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/entities?page=0&size=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "entities"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Get Entity Instance by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 OK', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response has correct id', function() {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.id).to.eql(pm.collectionVariables.get('entityInstanceId'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/entities/{{entityInstanceId}}"
          }
        },
        {
          "name": "Update Entity Instance",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 OK', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Attributes are updated', function() {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.attributes.price).to.eql(1099.99);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/v1/entities/{{entityInstanceId}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"entityTypeId\": \"{{entityTypeId}}\",\n    \"attributes\": {\n        \"name\": \"iPhone 15 Pro Max\",\n        \"price\": 1099.99,\n        \"inStock\": false\n    }\n}"
            }
          }
        },
        {
          "name": "Delete Entity Instance",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 204 No Content', function() {",
                  "    pm.response.to.have.status(204);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/entities/{{entityInstanceId}}"
          }
        }
      ]
    },
    {
      "name": "04 - Delete Entity Type (Cleanup)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 204 No Content', function() {",
              "    pm.response.to.have.status(204);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "url": "{{baseUrl}}/api/v1/entity-types/{{entityTypeId}}"
      }
    },
    {
      "name": "05 - Error Handling",
      "item": [
        {
          "name": "Get Non-existent Entity Type",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 404 Not Found', function() {",
                  "    pm.response.to.have.status(404);",
                  "});",
                  "pm.test('Error message is present', function() {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('message');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/entity-types/00000000-0000-0000-0000-000000000000"
          }
        },
        {
          "name": "Create Entity Type with Invalid Data",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400 Bad Request', function() {",
                  "    pm.response.to.have.status(400);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/entity-types",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"\",\n    \"description\": \"Test\"\n}"
            }
          }
        }
      ]
    }
  ]
}
